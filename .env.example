# ─────────────────────────────────────────────────────────────
# EPISTEME — environment variable template
# Copy this file to `.env` and fill in your own values.
# NEVER commit the real `.env` (it is gitignored).
#
# NOTE: In the n8n pipeline these keys are stored in n8n's own
# encrypted Credential store (Settings → Credentials), NOT in this
# file. This template documents every key the project needs so a
# reviewer knows what to provision. The two HTML dashboards read the
# key entered in their UI at runtime; nothing is hardcoded.
# ─────────────────────────────────────────────────────────────

# Google Gemini (primary cloud assessment model)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter (used for GPT-5.5, Opus 4.8, and the independent Llama-3.1-70B judge)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (DeepSeek-R1 verification in batch mode)
# https://console.groq.com/keys
GROQ_API_KEY=

# Typhoon (Thai-language clinical summary)
# https://opentyphoon.ai/
TYPHOON_API_KEY=

# NCBI / PubMed E-utilities (OPTIONAL — eutils works without a key at a lower
# rate limit; a key raises the limit from 3 to 10 requests/sec)
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# n8n public REST API key (OPTIONAL — only needed for the helper export
# scripts; create under n8n Settings → n8n API)
N8N_API_KEY=

# OpenFDA drug-label endpoint requires NO key for basic use.
# Local services need no keys: Ollama (http://localhost:11434) and the
# PyThaiNLP privacy NER service (http://127.0.0.1:5005).
